{
    "name": "peanutgraphic/formflow-lite",
    "description": "FormFlow Lite \u2014 API-integrated enrollment forms (free tier, FFFL namespace).",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.0",
        "peanut/formflow-core": "^0.5.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "wp-phpunit/wp-phpunit": "^6.4",
        "yoast/phpunit-polyfills": "^2.0"
    },
    "autoload-dev": {
        "psr-4": {
            "FFFL\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "platform": {
            "php": "8.2.0"
        },
        "allow-plugins": {}
    },
    "scripts": {
        "test": "phpunit",
        "test:property": "phpunit -c phpunit.property.xml",
        "test:contract": "phpunit -c phpunit.contract.xml",
        "test:contract-wp": "phpunit -c phpunit.contract-wp.xml"
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/Peanut-Graphic/formflow-core.git"
        }
    ]
}
