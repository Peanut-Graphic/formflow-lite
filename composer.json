{
    "name": "peanutgraphic/formflow-lite",
    "description": "FormFlow Lite — API-integrated enrollment forms (free tier, FFFL namespace).",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "scripts": {
        "test:property": "phpunit -c phpunit.property.xml",
        "test:contract": "phpunit -c phpunit.contract.xml"
    }
}
